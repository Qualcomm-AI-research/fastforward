# name: test_autoquant_skip_isolation_for_if_expr
  '''
  def my_func_with_annotations(self, x: Tensor, y: Tensor, flag: bool) -> Tensor:
      x = self.quantizer_x(x)
      y = self.quantizer_y(y)
