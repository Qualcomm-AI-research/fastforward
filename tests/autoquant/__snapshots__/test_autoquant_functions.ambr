# name: test_autoquant_shared_quantized_value[repeated_subscript_shared_quantized_value]
  '''
  def forward(self, x: torch.Tensor, idx: int) -> torch.Tensor:
      x = self.quantizer_x(x)
      y = fastforward.nn.functional.add(x, 1, output_quantizer=self.quantizer_add_1)
      _tmp_1 = self.quantizer_y_idx(y[idx])
      a = fastforward.nn.functional.mul(_tmp_1, 2, output_quantizer=self.quantizer_mul_1)
      b = fastforward.nn.functional.mul(_tmp_1, 3, output_quantizer=self.quantizer_mul_2)
      return fastforward.nn.functional.add(a, b, output_quantizer=self.quantizer_add_2)
  
  '''
