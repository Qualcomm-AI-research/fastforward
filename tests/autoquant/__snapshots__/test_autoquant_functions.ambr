# name: test_autoquant_load_before_assignment[loop_list_load_before_assignment]
  '''
  def forward(self, image_flags: list[int], lengths: torch.Tensor):
      valid_mask = []
      for flag, length in zip(image_flags, lengths):
          length = self.quantizer_length(length)
          _tmp_2 = fastforward.nn.functional.mul(
              self.quantizer__flag([flag]), length, output_quantizer=self.quantizer_mul
          )
          valid_mask.extend(_tmp_2)
      return valid_mask
  
