          _tmp_1 = fastforward.nn.functional.mul(_tmp_4, b, output_quantizer=self.quantizer_mul_1)
          _tmp_2 = fastforward.nn.functional.mul(_tmp_4, b, output_quantizer=self.quantizer_mul_2)
          _tmp_3 = fastforward.nn.functional.add(_tmp_1, _tmp_2, output_quantizer=self.quantizer_add)
          hw_list.extend(_tmp_3)
      return hw_list
  
  '''
