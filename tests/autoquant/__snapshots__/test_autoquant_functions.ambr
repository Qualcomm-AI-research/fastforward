  '''
  def forward(self, x: torch.Tensor, idx: int) -> torch.Tensor:
      x = self.quantizer_x(x)
      y = fastforward.nn.functional.add(x, 1, output_quantizer=self.quantizer_add_1)
      _tmp_1 = fastforward.nn.functional.mul(
          self.quantizer_y_idx(y[idx]), 0, output_quantizer=self.quantizer_mul
      )
      z = fastforward.nn.functional.add(_tmp_1, y, output_quantizer=self.quantizer_add_2)
      return z
  
