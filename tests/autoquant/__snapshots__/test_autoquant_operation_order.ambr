# name: test_quantize_statement_respects_reassignment_complex_model
  '''
  import fastforward
  import torch
  
  from tests.autoquant.test_autoquant_operation_order import (
      ComplexReassignmentModel,
      _repeat,
  )
  
  
  class QuantizedComplexReassignmentModel(fastforward.nn.QuantizedModule, ComplexReassignmentModel):
      def __init_quantization__(self) -> None:
          super().__init_quantization__()
          self.quantizer_add_1: fastforward.nn.Quantizer = fastforward.nn.QuantizerStub()
          self.quantizer_add_2: fastforward.nn.Quantizer = fastforward.nn.QuantizerStub()
          self.quantizer_matmul_1: fastforward.nn.Quantizer = fastforward.nn.QuantizerStub()
          self.quantizer_mul: fastforward.nn.Quantizer = fastforward.nn.QuantizerStub()
          self.quantizer_matmul_2: fastforward.nn.Quantizer = fastforward.nn.QuantizerStub()
          self.quantizer_q: fastforward.nn.Quantizer = fastforward.nn.QuantizerStub()
          self.quantizer_k_1: fastforward.nn.Quantizer = fastforward.nn.QuantizerStub()
          self.quantizer_v: fastforward.nn.Quantizer = fastforward.nn.QuantizerStub()
          self.quantizer_k_2: fastforward.nn.Quantizer = fastforward.nn.QuantizerStub()
          self.quantizer_k_T: fastforward.nn.Quantizer = fastforward.nn.QuantizerStub()
          self.quantizer_score_T: fastforward.nn.Quantizer = fastforward.nn.QuantizerStub()
  
      def forward(self, hidden_states: torch.Tensor) -> torch.Tensor:
          q = self.q_proj(hidden_states)
          q = self.quantizer_q(q)
          k = self.k_proj(hidden_states)
          k = self.quantizer_k_1(k)
          v = self.v_proj(hidden_states)
          v = self.quantizer_v(v)
          v = fastforward.nn.functional.add(v, k, output_quantizer=self.quantizer_add_1)
          k = fastforward.nn.functional.add(k, v, output_quantizer=self.quantizer_add_2)
          k = _repeat(k)
          k = self.quantizer_k_2(k)
          k_T = self.quantizer_k_T(k.T)
          score = fastforward.nn.functional.matmul(q, k_T, output_quantizer=self.quantizer_matmul_1)
          _tmp_8 = fastforward.nn.functional.mul(v, k, output_quantizer=self.quantizer_mul)
          score_T = self.quantizer_score_T(score.T)
          prob = fastforward.nn.functional.matmul(
              _tmp_8, score_T, output_quantizer=self.quantizer_matmul_2
          )
          return prob
  '''
