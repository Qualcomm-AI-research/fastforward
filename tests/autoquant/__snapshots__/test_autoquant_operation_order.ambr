# name: test_quantize_statement_respects_reassignment_accessing_object_property
  '''
  import fastforward
  import torch
  
  from tests.autoquant.test_autoquant_operation_order import (
      ReassignmentModelWithObjectProperty,
      TimeData,
      _repeat,
  )
  
  
  class QuantizedReassignmentModelWithObjectProperty(
      fastforward.nn.QuantizedModule, ReassignmentModelWithObjectProperty
  ):
      def __init_quantization__(self) -> None:
          super().__init_quantization__()
          self.quantizer_matmul: fastforward.nn.Quantizer = fastforward.nn.QuantizerStub()
          self.quantizer_q: fastforward.nn.Quantizer = fastforward.nn.QuantizerStub()
          self.quantizer_ts_T_T: fastforward.nn.Quantizer = fastforward.nn.QuantizerStub()
  
      def forward(self, hidden_states: torch.Tensor) -> torch.Tensor:
          q = self.q_proj(hidden_states)
          q = self.quantizer_q(q)
          k = self.k_proj(hidden_states)
          ts = TimeData(T=k)
          ts.T = _repeat(ts.T)
          ts_T_T = self.quantizer_ts_T_T(ts.T.T)
          return fastforward.nn.functional.matmul(q, ts_T_T, output_quantizer=self.quantizer_matmul)
  '''
