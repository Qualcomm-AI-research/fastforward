# serializer version: 1
# name: test_quantize_statement_respects_reassignment
  '''
  import fastforward
  import torch
  
  from tests.autoquant.test_autoquant_operation_order import ReassignmentModel, _repeat
  
  
  class QuantizedReassignmentModel(fastforward.nn.QuantizedModule, ReassignmentModel):
      def __init_quantization__(self) -> None:
          super().__init_quantization__()
          self.quantizer_matmul: fastforward.nn.Quantizer = fastforward.nn.QuantizerStub()
          self.quantizer_q: fastforward.nn.Quantizer = fastforward.nn.QuantizerStub()
          self.quantizer_k_T: fastforward.nn.Quantizer = fastforward.nn.QuantizerStub()
  
      def forward(self, hidden_states: torch.Tensor) -> torch.Tensor:
          q = self.q_proj(hidden_states)
          q = self.quantizer_q(q)
          k = self.k_proj(hidden_states)
          k = _repeat(k)
          k_T = self.quantizer_k_T(k.T)
          return fastforward.nn.functional.matmul(q, k_T, output_quantizer=self.quantizer_matmul)
  '''
